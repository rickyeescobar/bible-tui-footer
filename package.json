{
  "name": "bible-tui-footer",
  "version": "0.1.0",
  "description": "Read the King James Bible with RSVP while Pi agents work",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "effect",
    "rsvp",
    "bible",
    "kjv"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickyeescobar/bible-tui-footer.git"
  },
  "homepage": "https://github.com/rickyeescobar/bible-tui-footer#readme",
  "bugs": {
    "url": "https://github.com/rickyeescobar/bible-tui-footer/issues"
  },
  "files": [
    "extensions",
    "src",
    "data",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "video": "https://github.com/rickyeescobar/bible-tui-footer/releases/download/v0.1.0/bible-tui-footer-demo.mp4"
  },
  "scripts": {
    "build:data": "tsx scripts/compact-bible.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run check && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.99",
    "effect": "4.0.0-beta.99"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@effect/tsgo": "0.24.2",
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.15.1"
}
