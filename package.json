{
  "name": "bible-tui-footer",
  "version": "0.1.0",
  "description": "Read the King James Bible with RSVP while Pi agents work",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "effect",
    "rsvp",
    "bible",
    "kjv"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "src",
    "data",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "build:data": "tsx scripts/compact-bible.ts ../d4ilybread/data/kjv-bible.json data/kjv.json",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.99",
    "effect": "4.0.0-beta.99"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "@effect/tsgo": "0.24.2"
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "packageManager": "pnpm@11.15.1"
}
